MOCA_RELAYER_PRIVATE_KEY=0x...
MOCA_DEPLOY_TEST_TOKEN=true

# Deployed contract addresses
MOCA_GROTH16_VERIFIER=0x6F1FEb4D4051A994638298c5E3cc0cEdC50B8ee5
